# Legacy CRM Backend Environment Variables
# Copy this file to .env and fill in your real values

# ============================================================
# SERVER
# ============================================================
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:8080

# ============================================================
# DATABASE (MariaDB via XAMPP)
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=legacy
DB_USER=root
DB_PASSWORD=

# ============================================================
# AUTHENTICATION
# ============================================================
JWT_SECRET=legacy-crm-super-secret-jwt-key-2026-change-in-production
JWT_EXPIRES_IN=7d

# ============================================================
# GOOGLE CLOUD AI (Gemini)
# ============================================================
GOOGLE_AI_API_KEY=your-google-cloud-api-key-here
GOOGLE_AI_MODEL=gemini-1.5-flash

# ============================================================
# WHATSAPP (Evolution API - configure quando disponível)
# ============================================================
WHATSAPP_API_URL=http://localhost:8081
WHATSAPP_API_KEY=your-evolution-api-key
WHATSAPP_INSTANCE=legacy-crm
WEBHOOK_SECRET=legacy-webhook-secret-2026
